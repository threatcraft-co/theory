# Theory — API Key Configuration
# Copy this file to .env and fill in your keys.
# .env is gitignored and must never be committed.
#
# Registration links for each source are in config/sources.yaml.example

# AlienVault OTX — free registration at https://otx.alienvault.com/accounts/register
OTX_API_KEY=

# Malpedia — free registration at https://malpedia.caad.fkie.fraunhofer.de/register
MALPEDIA_API_KEY=

# NIST NVD — optional, raises rate limit. https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
